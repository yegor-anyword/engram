# Engram Configuration

# Server
ENGRAM_HOST=0.0.0.0
ENGRAM_PORT=5820
ENGRAM_LOG_LEVEL=info

# Storage backend: "sqlite" or "postgres"
ENGRAM_STORAGE_BACKEND=sqlite
ENGRAM_SQLITE_PATH=./engram.db

# PostgreSQL (when using postgres backend)
ENGRAM_POSTGRES_DSN=postgresql://engram:engram@localhost:5432/engram

# LLM Configuration (used by ingestion engine for concept extraction)
# LiteLLM supports: anthropic, openai, gemini, ollama, etc.
ENGRAM_LLM_MODEL=anthropic/claude-sonnet-4-6
ENGRAM_LLM_API_KEY=

# Embedding model (for concept similarity search)
ENGRAM_EMBEDDING_MODEL=text-embedding-3-small
ENGRAM_EMBEDDING_API_KEY=
